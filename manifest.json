{
  "manifest_version": 3,
  "name": "PromptEnhance",
  "version": "1.0.0",
  "description": "Enhance your AI prompts with the R.T.F. framework to maximize quality and minimize token costs.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PromptEnhance"
  }
}
